<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="64dp"
    android:paddingEnd="16dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="@drawable/bg_msg_mine"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/msg_photo"
            android:layout_width="160dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

        <TextView
            android:id="@+id/msg_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textIsSelectable="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/msg_edit_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_edit_profile_24"
                app:tint="?attr/colorOnSecondaryContainer"
                android:alpha="0.7"
                android:visibility="gone"
                tools:visibility="visible" />

            <ImageView
                android:id="@+id/msg_ephemeral_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_lock_24"
                app:tint="?attr/colorOnSecondaryContainer"
                android:alpha="0.7"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/msg_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:alpha="0.7"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                tools:text="18:43" />

            <ImageView
                android:id="@+id/msg_read_indicator"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_read_receipt"
                android:alpha="1.0"
                app:tint="?attr/colorSecondary"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
