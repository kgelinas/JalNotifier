<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorPrimaryContainer"
    android:gravity="bottom"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="56dp"
    android:paddingBottom="24dp"
    android:theme="@style/Theme.JALNotifier">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/nav_user_photo"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher_round"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:strokeColor="?attr/colorOnPrimaryContainer"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/nav_user_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="User Name"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textStyle="bold"
        android:textColor="?attr/colorOnPrimaryContainer" />

    <TextView
        android:id="@+id/nav_user_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Age • Location"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnPrimaryContainer"
        android:alpha="0.8" />

    <TextView
        android:id="@+id/nav_user_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:text="User ID: -"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?attr/colorOnPrimaryContainer"
        android:alpha="0.6" />

</LinearLayout>
