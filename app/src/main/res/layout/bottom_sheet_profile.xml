<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <!-- Drag Handle Pill -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="?android:attr/textColorHint" />

    <!-- Profile Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardElevation="0dp"
        app:cardCornerRadius="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/profile_sheet_avatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_background"
                    android:clipToOutline="true"
                    android:scaleType="centerCrop"
                    tools:src="@android:color/darker_gray" />

                <View
                    android:id="@+id/profile_sheet_online_indicator"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/online_dot"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </FrameLayout>

            <TextView
                android:id="@+id/profile_sheet_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textStyle="bold"
                tools:text="Jack86x22" />

            <TextView
                android:id="@+id/profile_sheet_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?android:attr/textColorSecondary"
                tools:text="44 ans • 1,90 m (6'3'')" />

            <TextView
                android:id="@+id/profile_sheet_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?android:attr/textColorSecondary"
                tools:text="Chaudière-Appalaches, Québec" />

            <!-- User Status Row -->
            <LinearLayout
                android:id="@+id/profile_sheet_status_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_status_bubble"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/profile_sheet_status_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_chat_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/profile_sheet_status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:gravity="start|center_vertical"
                    tools:text="Set a status..." />

                <ImageButton
                    android:id="@+id/profile_sheet_status_edit"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_edit_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@string/status_edit_title" />

                <ImageButton
                    android:id="@+id/profile_sheet_status_delete"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_delete_24"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="?attr/colorError"
                    android:visibility="gone"
                    android:contentDescription="@string/delete" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- Action Icons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp">

        <!-- Appear Offline (Ghost Mode) -->
        <ImageButton
            android:id="@+id/btn_profile_appear_offline"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_ghost"
            android:contentDescription="@string/appear_offline"
            app:tint="?attr/colorOnSurface" />

        <!-- Read Receipts -->
        <ImageButton
            android:id="@+id/btn_profile_read_receipts"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_read_receipt"
            android:contentDescription="@string/read_receipts"
            app:tint="?attr/colorOnSurface" />

        <!-- NSFW Blur -->
        <ImageButton
            android:id="@+id/btn_profile_nsfw"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nsfw"
            android:contentDescription="@string/nsfw_blur"
            app:tint="?attr/colorOnSurface" />

        <!-- Geolocation -->
        <ImageButton
            android:id="@+id/btn_profile_geolocation"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_my_location_24"
            android:contentDescription="@string/geolocation"
            app:tint="?attr/colorOnSurface" />

        <!-- Clean up chats -->
        <ImageButton
            android:id="@+id/btn_profile_cleanup"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_sweep_24"
            android:contentDescription="@string/action_cleanup_threads"
            app:tint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <!-- Bottom Actions Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="16dp">

        <!-- Settings -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_profile_settings"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            app:icon="@drawable/ic_settings_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:contentDescription="@string/settings" />

        <!-- Logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_profile_logout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/logout"
            app:icon="@drawable/ic_logout"
            app:backgroundTint="?attr/colorError"
            android:textColor="?attr/colorOnError"
            app:iconTint="?attr/colorOnError" />

    </LinearLayout>


</LinearLayout>
